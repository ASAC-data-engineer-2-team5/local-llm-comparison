# AWS 자격증명 (IAM 콘솔에서 발급)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2

# EC2 인스턴스
EC2_INSTANCE_ID=                    # ec2_create.sh 실행 시 자동 입력됨
EC2_KEY_NAME=                       # AWS 콘솔 키 페어 이름 (예: my-key)
EC2_KEY_PATH=                       # 로컬 pem 파일 경로 (예: ~/.ssh/my-key.pem)
EC2_USER=ubuntu                     # Ubuntu AMI 기본값

# Ollama (ec2_start.sh 실행 시 OLLAMA_HOST 자동 업데이트됨)
OLLAMA_HOST=
OLLAMA_MODEL=phi4-mini:q4_K_M      # 기본 테스트 모델
